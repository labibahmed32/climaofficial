RewriteEngine On

# Clean URLs: /api/click → /api/click.html
RewriteRule ^api/click$ /api/click.html [L,QSA]

# Clean URLs: /api/postback → /api/postback.html
RewriteRule ^api/postback$ /api/postback.html [L,QSA]

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
