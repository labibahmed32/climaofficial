{
  "rules": {
    "users": {
      ".read": true,
      ".write": true
    },
    "affiliates": {
      ".read": true,
      ".write": true
    },
    "managers": {
      ".read": true,
      ".write": true
    },
    "offers": {
      ".read": true,
      ".write": true
    },
    "clicks": {
      ".read": true,
      ".write": true,
      ".indexOn": ["timestamp", "affiliateId", "offerId"]
    },
    "conversions": {
      ".read": true,
      ".write": true,
      ".indexOn": ["affiliateId", "offerId", "createdAt", "clickId"]
    },
    "signups": {
      ".read": true,
      ".write": true
    },
    "payments": {
      ".read": true,
      ".write": true
    },
    "settings": {
      ".read": true,
      ".write": true
    },
    "postback-log": {
      ".read": true,
      ".write": true,
      ".indexOn": ["timestamp"]
    },
    "offer_applications": {
      ".read": true,
      ".write": true,
      ".indexOn": ["affiliateId", "offerId", "status"]
    },
    "offerAssignments": {
      ".read": true,
      ".write": true
    },
    "affiliateIndex": {
      ".read": true,
      ".write": true
    },
    "advertisers": {
      ".read": true,
      ".write": true
    },
    "dashboard": {
      ".read": true,
      ".write": true
    },
    "tracker": {
      "visitors": {
        ".read": "auth != null",
        ".write": true,
        "$date": {
          ".indexOn": [".value", "ipv4"]
        }
      },
      "checkout-sessions": {
        ".read": "auth != null",
        ".write": true
      },
      "upsell-events": {
        ".read": "auth != null",
        ".write": true
      },
      "thankyou-events": {
        ".read": "auth != null",
        ".write": true
      },
      "fraud-checks": {
        ".read": "auth != null",
        ".write": true
      },
      "sales": {
        ".read": "auth != null",
        ".write": true,
        ".indexOn": ["date", "affId", "offerId", "status", "subId", "orderIdGlobal"]
      },
      "offers": {
        ".read": true,
        ".write": "auth != null"
      },
      "settings": {
        ".read": true,
        ".write": "auth != null"
      },
      "ipqs": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
